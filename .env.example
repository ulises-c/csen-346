# Consultant agent
# RTX 5090: serve Qwen3.5-9B locally on port 8002 (no API key needed)
# RTX 3070: use OpenAI API (no VRAM to spare for a second local model)
CONSULTANT_API_KEY=not-needed
CONSULTANT_BASE_URL=http://localhost:8002/v1
CONSULTANT_MODEL_NAME=Qwen3.5-9B

# Teacher agent (SocratTeachLLM served locally on port 8001)
TEACHER_API_KEY=not-needed
TEACHER_BASE_URL=http://localhost:8001/v1
TEACHER_MODEL_NAME=SocratTeachLLM

# System settings
DEBUG_MODE=true
MAX_TEACHING_ROUNDS=8

# RTX 3070 only — used by src/project/serve_teacher.py (transformers + bitsandbytes NF4)
# Leave blank on the 5090 (vLLM is used there instead)
TEACHER_LOCAL_PATH=~/hf_models/SocratTeachLLM
TEACHER_HOST=0.0.0.0
TEACHER_PORT=8001
MAX_NEW_TOKENS=512
