# Consultant agent (baseline/gemma4 experiments use OpenAI GPT-4o to match the paper)
# configs/<experiment>.env sets CONSULTANT_BASE_URL + CONSULTANT_MODEL_NAME.
# Put the OpenAI key here in .env — it is gitignored.
CONSULTANT_API_KEY=sk-your-openai-key-here

# RTX 3070 fallback: use Gemini 2.5 Flash via Google AI Studio (free tier, no VRAM needed)
# CONSULTANT_API_KEY=your-google-ai-studio-key
# Override CONSULTANT_BASE_URL and CONSULTANT_MODEL_NAME in the experiment config.

# Teacher agent (SocratTeachLLM served locally on port 8001)
TEACHER_API_KEY=not-needed
TEACHER_BASE_URL=http://localhost:8001/v1
TEACHER_MODEL_NAME=SocratTeachLLM

# System settings
DEBUG_MODE=true
MAX_TEACHING_ROUNDS=8

# RTX 3070 only — used by src/project/serve_teacher.py (transformers + bitsandbytes NF4)
# Leave blank on the 5090 (vLLM is used there instead)
TEACHER_LOCAL_PATH=~/hf_models/SocratTeachLLM
TEACHER_HOST=0.0.0.0
TEACHER_PORT=8001
MAX_NEW_TOKENS=512

# Optional: require auth before serving the teacher model online.
# If set, clients must send either:
#   Authorization: Bearer <key>
# or:
#   x-api-key: <key>
TEACHER_SERVER_API_KEY=
