# Experiment: Fully local dual-GPU run (2× RTX 3090 Ti, 24 GB each)
# Teacher:    SocratTeachLLM on GPU 0, port 8001  (make serve-dual-gpu)
# Consultant: Qwen3.5-9B     on GPU 1, port 8002  (make serve-dual-gpu)
# Note: serve scripts auto-select float16 on CC < 8.0 (3090 Ti is CC 8.6 → bfloat16 OK)

CONSULTANT_API_KEY=not-needed
CONSULTANT_BASE_URL=http://localhost:8002/v1
CONSULTANT_MODEL_NAME=Qwen3.5-9B

TEACHER_API_KEY=not-needed
TEACHER_BASE_URL=http://localhost:8001/v1
TEACHER_MODEL_NAME=SocratTeachLLM

DEBUG_MODE=false
MAX_TEACHING_ROUNDS=8
