# Experiment: Baseline (reproducing paper)
# Teacher: SocratTeachLLM (GLM4-9B fine-tune) — the paper's original model
# Consultant: GPT-4o via OpenAI API — matches the paper's original setup.
#             (Local 2B emitted bare integer state IDs; 4B didn't fit in VRAM
#             alongside the teacher. GPT-4o is both faithful to the paper and
#             frees ~10 GB of VRAM on the 5090.)
#
# CONSULTANT_API_KEY is loaded from .env (OPENAI key; do NOT commit the key here).

CONSULTANT_BASE_URL=https://api.openai.com/v1
CONSULTANT_MODEL_NAME=gpt-4o-2024-11-20

TEACHER_API_KEY=not-needed
TEACHER_BASE_URL=http://localhost:8001/v1
TEACHER_MODEL_NAME=SocratTeachLLM

DEBUG_MODE=false
MAX_TEACHING_ROUNDS=8
