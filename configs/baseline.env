# Experiment: Baseline (reproducing paper)
# Teacher: SocratTeachLLM (GLM4-9B fine-tune) — the paper's original model
# Consultant: Qwen3.5-4B (replaces GPT-4 from paper; 4B is the largest that fits
#             alongside teacher on 32GB. 2B was too weak — emitted bare state
#             integers instead of "a0"/"b2"/etc, killing state accuracy.)

CONSULTANT_API_KEY=not-needed
CONSULTANT_BASE_URL=http://localhost:8002/v1
CONSULTANT_MODEL_NAME=Qwen3.5-4B

TEACHER_API_KEY=not-needed
TEACHER_BASE_URL=http://localhost:8001/v1
TEACHER_MODEL_NAME=SocratTeachLLM

DEBUG_MODE=false
MAX_TEACHING_ROUNDS=8
