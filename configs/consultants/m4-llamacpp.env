# Qwen3.5-9B served via llama.cpp on Mac Mini M4 (16 GB unified memory).
# Start with: source configs/consultants/m4-llamacpp.env && ./scripts/serve_consultant_llamacpp.sh
# Set CONSULTANT_MODEL_PATH to the actual .gguf path on the Mac Mini.
CONSULTANT_API_KEY=no-key
CONSULTANT_BASE_URL=http://Ulisess-Mac-mini.local:8080/v1
CONSULTANT_MODEL_NAME=Qwen3.5-9B-UD-Q6_K_XL
CONSULTANT_MODEL_PATH=${HOME}/models/Qwen3.5-9B-UD-Q6_K_XL.gguf
CONSULTANT_GPU_LAYERS=99
CONSULTANT_NUM_CTX=16384
CONSULTANT_MAX_TOKENS=8192
CONSULTANT_DISABLE_THINKING=true
CONSULTANT_THINKING_BUDGET=0
