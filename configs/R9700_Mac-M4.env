CONSULTANT_API_KEY=no-key
CONSULTANT_BASE_URL=http://Ulisess-Mac-mini.local:8080/v1
CONSULTANT_MODEL_NAME=Qwen3.5-9B
# Path to the .gguf file on the Mac Mini — update to match your download location.
CONSULTANT_MODEL_PATH=${HOME}/models/Qwen3.5-9B-Q4_K_M.gguf
CONSULTANT_GPU_LAYERS=99
CONSULTANT_NUM_CTX=16384
CONSULTANT_MAX_TOKENS=8192
CONSULTANT_DISABLE_THINKING=false

TEACHER_API_KEY=not-needed
TEACHER_BASE_URL=http://localhost:8001/v1
TEACHER_MODEL_NAME=SocratTeachLLM

DEBUG_MODE=false
MAX_TEACHING_ROUNDS=8
