# Experiment: WAVE local serving (any NVIDIA GPU node)
# Teacher: SocratTeachLLM on localhost:8001
# Consultant: Qwen3.5-9B on localhost:8002
#
# Use this when both models are served on a WAVE node via scripts/slurm/wave_eval.slurm.

CONSULTANT_API_KEY=not-needed
CONSULTANT_BASE_URL=http://127.0.0.1:8002/v1
