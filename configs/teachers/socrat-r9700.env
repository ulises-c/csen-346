# SocratTeachLLM served via HF Transformers on AMD R9700 AI PRO.
# vLLM lacks stable gfx1201 (RDNA 4) support as of April 2026; BNB skipped
# because 32 GB VRAM fits the model in full precision.
# Start with: ./scripts/serve_teacher_local.sh
TEACHER_API_KEY=not-needed
TEACHER_BASE_URL=http://localhost:8001/v1
TEACHER_MODEL_NAME=SocratTeachLLM
TEACHER_LOCAL_PATH=${HOME}/hf_models/SocratTeachLLM
TEACHER_HOST=0.0.0.0
TEACHER_PORT=8001
MAX_NEW_TOKENS=2048
TEACHER_USE_BNB=false
