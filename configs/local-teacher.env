# Teacher server config for local eval (AMD/bitsandbytes, no API key).
# Source this before running serve_teacher_local.sh, or export manually.
#
# Usage:
#   set -a && source configs/local-teacher.env && set +a
#   ./scripts/serve_teacher_local.sh

TEACHER_LOCAL_PATH=$HOME/hf_models/SocratTeachLLM
TEACHER_HOST=0.0.0.0
TEACHER_PORT=8001
MAX_NEW_TOKENS=2048
# TEACHER_SERVER_API_KEY intentionally unset — disables auth for local use
# Skip bitsandbytes: R9700 has 32 GB VRAM so quantization is unnecessary,
# and bitsandbytes ROCm support for gfx1201 (RDNA 4) is not yet reliable.
TEACHER_USE_BNB=false
